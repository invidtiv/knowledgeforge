[Unit]
Description=KnowledgeForge File Watcher
After=network.target knowledgeforge-api.service

[Service]
Type=simple
User=bsdev
WorkingDirectory=/home/bsdev/knowledgeforge
ExecStart=/home/bsdev/knowledgeforge/.venv/bin/python -m knowledgeforge.interfaces.cli watch
Restart=on-failure
RestartSec=10
Environment=KNOWLEDGEFORGE_CONFIG=/home/bsdev/knowledgeforge/config.yaml

[Install]
WantedBy=multi-user.target
