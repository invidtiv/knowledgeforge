# KnowledgeForge Environment Variables
# All config values can be overridden with KNOWLEDGEFORGE_ prefix

# KNOWLEDGEFORGE_DATA_DIR=~/.local/share/knowledgeforge
# KNOWLEDGEFORGE_OBSIDIAN_VAULT_PATH=~/Documents/ObsidianVault
# Use the same OpenRouter-backed embedding path as OB1.
# Put real secrets in ~/.config/knowledgeforge/secrets.env, not in this file.
KNOWLEDGEFORGE_EMBEDDING_PROVIDER=openrouter
KNOWLEDGEFORGE_EMBEDDING_MODEL=openai/text-embedding-3-small
# OPENROUTER_API_KEY=<openrouter-api-key>
# Optional fallback if explicitly using OpenAI directly:
# OPENAI_API_KEY=<openai-api-key>
# Optional OB1 bridge settings:
# KNOWLEDGEFORGE_OB1_SUPABASE_URL=https://your-project.supabase.co
# KNOWLEDGEFORGE_OB1_SUPABASE_KEY=<service-role-key>
# KNOWLEDGEFORGE_OB1_ACCESS_KEY=<openbrain-access-key>
# Set KNOWLEDGEFORGE_EMBEDDING_PROVIDER=local to force the old CPU model.
# Primary Kimi model used by episodic-memory enrichment.
KNOWLEDGEFORGE_KIMI_MODEL=kimi-code/kimi-for-coding
# KNOWLEDGEFORGE_EMBEDDING_DEVICE=cpu
# KNOWLEDGEFORGE_REST_HOST=127.0.0.1
# KNOWLEDGEFORGE_REST_PORT=8742
# KNOWLEDGEFORGE_CONFIG=/path/to/config.yaml
